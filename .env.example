# === База данных ===
DATABASE_URL=sqlite+aiosqlite:///./gateway.db

# === Безопасность UI (HTTP Basic Auth) ===
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_strong_password

# === Защита Webhook-эндпоинта ===
WEBHOOK_SECRET=changeme_webhook_token_here

# === Portkey (провайдер по умолчанию) ===
PORTKEY_API_KEY=pk-xxx-your-key
PORTKEY_BASE_URL=https://api.portkey.ai/v1

# === Таймауты внешних вызовов (секунды) ===
EXTERNAL_HTTP_TIMEOUT=30
