# ══════════════════════════════════════════════════════════════════════
# AI Gateway — Environment Configuration Example
# ══════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in real values:
#   cp .env.example .env
# NEVER commit .env with real secrets to version control!
# ══════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/gateway.db

# ── Admin credentials ─────────────────────────────────────────────────
ADMIN_USERNAME=gateway_operator
ADMIN_PASSWORD=Str0ng!Pass#2024

# ── Webhook ───────────────────────────────────────────────────────────
# Minimum 16 characters
WEBHOOK_SECRET=CHANGE_ME_webhook_secret_min16chars

# ── Encryption (Fernet key, 44 base64 chars → 32 bytes) ──────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_generate_new_fernet_key_44chars

# ── External HTTP timeout (seconds, range 5–120) ─────────────────────
EXTERNAL_HTTP_TIMEOUT=30

# ── Demo mode (returns simulated responses when no LLM API key) ──────
DEMO_MODE=false

# ── CORS Origins (comma-separated, used by backend) ──────────────────
CORS_ORIGINS=http://localhost:3000

# ── Frontend (build-time & runtime) ──────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Docker deployment ────────────────────────────────────────────────
IMAGE_NAME=ai-gateway-backend:latest
FRONTEND_IMAGE_NAME=ai-gateway-frontend:latest
BACKEND_PORT=8000
FRONTEND_PORT=3000
